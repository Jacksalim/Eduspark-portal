# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Resend (email delivery) ───────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
# In Vercel: Settings → Environment Variables → add RESEND_API_KEY
# IMPORTANT: Do NOT add a VITE_ prefix — this is server-side only.
RESEND_API_KEY=re_your_resend_api_key_here

# Sender address for outgoing emails.
# • Testing (no domain verification needed): leave blank → uses Resend's shared domain
# • Production: use your verified domain, e.g. noreply@eduspark.co.ke
# Format: "Display Name <email@domain.com>"
RESEND_FROM_EMAIL=EduSpark <noreply@eduspark.co.ke>

# Your deployed app URL — used in email links.
# Example: https://eduspark.vercel.app
APP_URL=https://your-app.vercel.app

# ─── Anthropic Claude (AI Quiz) ────────────────────────────────────────────────
# Get from: https://console.anthropic.com
# IMPORTANT: Do NOT add a VITE_ prefix — this is server-side only.
ANTHROPIC_KEY=sk-ant-your-key-here

# Optional: override the Claude model (defaults to claude-opus-4-5 with fallbacks)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
