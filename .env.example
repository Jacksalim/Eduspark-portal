# Supabase — get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic Claude API key — get from console.anthropic.com
# IMPORTANT: Do NOT add a VITE_ prefix here.
# This key must stay server-side (used only in api/quiz.js serverless function).
# Add this exact name to Vercel: Settings → Environment Variables → ANTHROPIC_KEY
ANTHROPIC_KEY=sk-ant-your-key-here

# Optional: override the Claude model (defaults to claude-opus-4-5)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
