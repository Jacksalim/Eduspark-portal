# ─── Supabase (client) ─────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase CLI (local dev & db:push) ────────────────────────────────────────
# Project ref: Dashboard → your project → Settings → General → Reference ID
SUPABASE_PROJECT_REF=your-project-ref
# DB password: Dashboard → Settings → Database → Database password
SUPABASE_DB_PASSWORD=your-database-password

# ─── Resend (email delivery) ────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
# In Vercel: Settings → Environment Variables → add RESEND_API_KEY
# IMPORTANT: Do NOT add a VITE_ prefix — this is server-side only.
RESEND_API_KEY=re_your_resend_api_key_here

# Sender address for outgoing emails.
# Testing (no domain verification needed): leave blank → uses Resend shared domain
# Production: use your verified domain e.g. noreply@eduspark.co.ke
RESEND_FROM_EMAIL=EduSpark <noreply@eduspark.co.ke>

# Your deployed app URL — used in email links.
APP_URL=https://your-app.vercel.app

# ─── AI Quiz Generation ─────────────────────────────────────────────────────────
# Google Gemini (Primary) — https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (Fallback) — https://console.anthropic.com/account/keys
# IMPORTANT: Do NOT add a VITE_ prefix — server-side only.
ANTHROPIC_API_KEY=sk-ant-your-key-here
